{
  "name": "@netcracker/qubership-apihub-compatibility-suites",
  "version": "2.4.1",
  "license": "Apache-2.0",
  "type": "module",
  "module": "./dist/index.es.js",
  "main": "./dist/index.cjs.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run generate && vite build",
    "development:link": "npm link",
    "development:unlink": "npm unlink",
    "generate": "tsx bin/generate-suite-data.ts",
    "type-check": "npm run generate && tsc -p tsconfig.json --noEmit",
    "update-lock-file": "update-lock-file @netcracker"
  },
  "devDependencies": {
    "@netcracker/qubership-apihub-npm-gitflow": "3.1.0",
    "@types/js-yaml": "4.0.9",
    "@types/node": "25.0.3",
    "js-yaml": "4.1.1",
    "tslib": "2.8.1",
    "tsx": "4.8.1",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vite-plugin-dts": "4.5.4"
  }
}
