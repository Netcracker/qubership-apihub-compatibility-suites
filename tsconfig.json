{
  "compilerOptions": {
    "target": "esnext",
    "module": "ESNext",
    "allowJs": false,
    "outDir": "dist",
    "importHelpers": true,
    "strict": true,
    "moduleResolution": "bundler",
    "typeRoots": [
      "types",
      "node_modules/@types"
    ],
    "esModuleInterop": true,
    "pretty": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "index.ts",
    "bin/**/*.ts",
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
